import bisect
from collections import defaultdict
from typing import List

class Solution:
    def equalSumGridPartitionII(self, grid: List[List[int]]) -> bool:
        m = len(grid)
        n = len(grid[0])
        total = sum(sum(row) for row in grid)

        # ----- prefix sums for rows -----
        row_sums = [sum(row) for row in grid]
        cum_row = [0] * (m + 1)
        for i in range(m):
            cum_row[i + 1] = cum_row[i] + row_sums[i]

        # ----- maps from value to sorted list of rows / columns (1‑based) -----
        rows_by_val = defaultdict(list)
        cols_by_val = defaultdict(list)
        for i in range(m):
            for j in range(n):
                v = grid[i][j]
                rows_by_val[v].append(i + 1)
                cols_by_val[v].append(j + 1)
        for lst in rows_by_val.values():
            lst.sort()
        for lst in cols_by_val.values():
            lst.sort()

        # ----- helpers for existence queries -----
        def has_row_in_range(val: int, low: int, high: int) -> bool:
            """Is there a cell with value `val` whose row lies in [low, high]?"""
            if val not in rows_by_val:
                return False
            rows = rows_by_val[val]
            idx = bisect.bisect_left(rows, low)
            return idx < len(rows) and rows[idx] <= high

        def has_col_in_range(val: int, low: int, high: int) -> bool:
            """Is there a cell with value `val` whose column lies in [low, high]?"""
            if val not in cols_by_val:
                return False
            cols = cols_by_val[val]
            idx = bisect.bisect_left(cols, low)
            return idx < len(cols) and cols[idx] <= high

        def has_row_exact(val: int, row: int) -> bool:
            """Does a cell with value `val` exist exactly at row `row`?"""
            if val not in rows_by_val:
                return False
            rows = rows_by_val[val]
            idx = bisect.bisect_left(rows, row)
            return idx < len(rows) and rows[idx] == row

        def has_col_exact(val: int, col: int) -> bool:
            """Does a cell with value `val` exist exactly at column `col`?"""
            if val not in cols_by_val:
                return False
            cols = cols_by_val[val]
            idx = bisect.bisect_left(cols, col)
            return idx < len(cols) and cols[idx] == col

        # ----- horizontal cuts -----
        for r in range(1, m):
            sum_top = cum_row[r]
            # no discount
            if sum_top * 2 == total:
                return True

            # discount a cell from the top section
            v_top = 2 * sum_top - total
            if v_top > 0:
                if n == 1:               # grid is a single column
                    # top is rows 1..r, must remove an end cell (row 1 or row r)
                    if has_row_exact(v_top, 1) or has_row_exact(v_top, r):
                        return True
                elif r == 1:             # top is a single row
                    # must remove a cell at column 1 or column n
                    if grid[0][0] == v_top or grid[0][n - 1] == v_top:
                        return True
                else:                    # general case (at least 2 rows and 2 columns)
                    if has_row_in_range(v_top, 1, r):
                        return True

            # discount a cell from the bottom section
            v_bottom = total - 2 * sum_top
            if v_bottom > 0:
                if n == 1:               # grid is a single column
                    # bottom is rows r+1..m, must remove an end cell (row r+1 or row m)
                    if has_row_exact(v_bottom, r + 1) or has_row_exact(v_bottom, m):
                        return True
                elif m - r == 1:         # bottom is a single row
                    if grid[m - 1][0] == v_bottom or grid[m - 1][n - 1] == v_bottom:
                        return True
                else:                    # general case
                    if has_row_in_range(v_bottom, r + 1, m):
                        return True

        # ----- prefix sums for columns -----
        col_sums = [0] * n
        for j in range(n):
            for i in range(m):
                col_sums[j] += grid[i][j]
        cum_col = [0] * (n + 1)
        for j in range(n):
            cum_col[j + 1] = cum_col[j] + col_sums[j]

        # ----- vertical cuts -----
        for c in range(1, n):
            sum_left = cum_col[c]
            if sum_left * 2 == total:
                return True

            # discount a cell from the left section
            v_left = 2 * sum_left - total
            if v_left > 0:
                if m == 1:               # grid is a single row
                    # left is columns 1..c, must remove an end cell (col 1 or col c)
                    if grid[0][0] == v_left or grid[0][c - 1] == v_left:
                        return True
                elif c == 1:             # left is a single column
                    # must remove a cell at row 1 or row m
                    if grid[0][0] == v_left or grid[m - 1][0] == v_left:
                        return True
                else:                    # general case
                    if has_col_in_range(v_left, 1, c):
                        return True

            # discount a cell from the right section
            v_right = total - 2 * sum_left
            if v_right > 0:
                if m == 1:               # grid is a single row
                    # right is columns c+1..n, must remove an end cell (col c+1 or col n)
                    if grid[0][c] == v_right or grid[0][n - 1] == v_right:
                        return True
                elif n - c == 1:         # right is a single column
                    if grid[0][n - 1] == v_right or grid[m - 1][n - 1] == v_right:
                        return True
                else:                    # general case
                    if has_col_in_range(v_right, c + 1, n):
                        return True

        return False
